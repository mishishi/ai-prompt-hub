{
  "name": "ai-prompt-bench",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,app -c blue,green \"node --import tsx --env-file=.env.local --env-file=.env server/index.ts\" \"vite --port 3006\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "dev:server": "node --import tsx --env-file=.env.local --env-file=.env server/index.ts"
  },
  "dependencies": {
    "@clerk/backend": "^3.4.11",
    "@clerk/clerk-react": "^5.61.6",
    "@fastify/cors": "^11.2.0",
    "@neondatabase/serverless": "^1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vercel/kv": "^2.0.0",
    "concurrently": "^9.2.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "js-yaml": "^4.1.1",
    "lucide-react": "^1.14.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0",
    "recharts": "^3.8.1",
    "tailwindcss": "^4.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.8.1",
    "@vitejs/plugin-react": "^6.0.1",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.60.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  }
}
